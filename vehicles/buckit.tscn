[sub_resource type="GDScript" id="GDScript_vq86v"]
script/source = "extends Node
## OPTIONAL: Traction Control System
## Attach this as a CHILD of VehicleBody3D to add traction control
## If not attached, vehicle works normally without it

@export_group(\"Traction Control\")
@export var enabled: bool = true
@export var max_wheel_slip: float = 0.15  # 15% slip = optimal for drag racing
@export var power_reduction_rate: float = 0.8  # How aggressively to cut power (0-1)

@export_group(\"Launch Control\") 
@export var launch_control_enabled: bool = true
@export var launch_power_limit: float = 0.7  # Limit to 70% power at launch
@export var launch_speed_threshold: float = 20.0  # m/s - disable after this speed

# Internal state (exposed for debug overlay)
var traction_control_active: bool = false
var is_launching: bool = false

var vehicle: VehicleBody3D
var wheels: Array[VehicleWheel3D] = []

func _ready():
	vehicle = get_parent() as VehicleBody3D
	if not vehicle:
		push_error(\"TractionControl must be child of VehicleBody3D!\")
		queue_free()
		return
	
	# Find all wheels
	for child in vehicle.get_children():
		if child is VehicleWheel3D:
			wheels.append(child)
	
	if wheels.is_empty():
		push_error(\"No wheels found!\")
		queue_free()
		return
	
	print(\"[TC] Traction Control ready on %s\" % vehicle.name)

func _physics_process(_delta):
	if not enabled or not is_instance_valid(vehicle):
		return
	
	var speed = vehicle.linear_velocity.length()
	
	# Launch control mode (low speed + high throttle)
	if launch_control_enabled and speed < launch_speed_threshold:
		var max_force = vehicle.get(\"max_engine_force\")
		if max_force != null and vehicle.engine_force > max_force * 0.5:
			is_launching = true
			vehicle.engine_force = min(vehicle.engine_force, max_force * launch_power_limit)
		else:
			is_launching = false
	else:
		is_launching = false
	
	# Check for wheel slip on driven wheels
	var max_slip_detected = 0.0
	var slipping_wheels = 0
	
	for wheel in wheels:
		# Only check wheels that provide traction
		if not wheel.use_as_traction:
			continue
		
		if wheel.is_in_contact():
			var skid_info = wheel.get_skidinfo()
			var slip = 1.0 - skid_info  # Convert to slip (0=no slip, 1=full slip)
			
			if slip > max_slip_detected:
				max_slip_detected = slip
			
			if slip > max_wheel_slip:
				slipping_wheels += 1
	
	# Reduce power if wheels are slipping
	if slipping_wheels > 0:
		traction_control_active = true
		
		var slip_percentage = max_slip_detected
		var power_multiplier = 1.0 - (slip_percentage * power_reduction_rate)
		power_multiplier = clamp(power_multiplier, 0.3, 1.0)  # Never below 30%
		
		vehicle.engine_force *= power_multiplier
	else:
		traction_control_active = false

func toggle():
	\"\"\"Allow toggling TC on/off during race\"\"\"
	enabled = !enabled
	print(\"[TC] Traction Control: %s\" % (\"ON\" if enabled else \"OFF\"))
"

